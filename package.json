{
  "name": "@semirhuduti/opencode-tts-voice",
  "version": "0.3.0-alpha.11",
  "description": "Kokoro voice output plugin for OpenCode with TUI shortcuts",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "tts",
    "voice",
    "kokoro",
    "tui"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    "./tui": {
      "types": "./dist/tui-plugin.d.ts",
      "import": "./dist/tui-plugin.js"
    }
  },
  "scripts": {
    "build": "node ./scripts/clean-dist.mjs && tsc -p tsconfig.json && bun run ./scripts/build-tui.ts",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "opencode": "^1.14.24"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/semirhuduti/opencode-tts-voice.git"
  },
  "homepage": "https://github.com/semirhuduti/opencode-tts-voice",
  "bugs": {
    "url": "https://github.com/semirhuduti/opencode-tts-voice/issues"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.5.1",
    "@opencode-ai/plugin": "^1.14.24",
    "@opentui/core": "^0.1.103",
    "@opentui/solid": "^0.1.103",
    "kokoro-js": "^1.2.1",
    "solid-js": "1.9.11"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
